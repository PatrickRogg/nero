#!/usr/bin/env bash
# Copy to workspace-setup.sh next to this file, make executable, customize.
# Runs on every `nero install` / `nero update` after the workspace template
# is merged and GitHub/git identity is configured (so git clone and gh work).
#
# Environment (set by the installer):
#   WORKSPACE_ROOT   Nero agent workspace (…/workspace/agents)
#   NERO_PROJECT_DIR Nero project root (compose, config, …)
#   NERO_SOURCE_DIR  Directory where install.sh lives (often same as project)
#   NERO_SSH_DIR     config/ssh (id_ed25519 for Git if generated)
#   NERO_GIT_CONFIG  Path to the gitconfig used by the stack
#   GH_CONFIG_DIR    gh CLI config (when GitHub integration is enabled)
#   GIT_CONFIG_GLOBAL / GIT_SSH_COMMAND set when applicable
#
# Skip: SKIP_WORKSPACE_SETUP=1 in .env
# Custom path: WORKSPACE_SETUP_SCRIPT=/absolute/path/setup.sh in .env

set -euo pipefail

cd "${WORKSPACE_ROOT}"

# Example: clone a repo into code/
# mkdir -p code
# git clone git@github.com:you/your-repo.git code/your-repo

# Example: fetch a dataset
# curl -fsSL https://example.com/data.tgz -o drop/data.tgz

exit 0

{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "permission": "allow",
  "instructions": ["Agents.md", ".agents/SOUL.md"],
  "plugin": [
    "opencode-cursor-oauth"
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    },
    "cursor": {
      "name": "Cursor"
    }
  }
}
